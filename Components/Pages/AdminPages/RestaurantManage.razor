@*Admin Restaurant Approval Page*@
@page "/Admin/restaurant/manage"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Dinesaur.Domain
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider Auth
@inject IDbContextFactory<Dinesaur.Data.DinesaurContext> DbFactory
@inject UserManager<Dinesaur.Data.DinesaurUser> UserManager

        <!-- Main container for the admin page -->
        <div style="width: 100%; color: white; padding: 50px; align-items: center;">

            <!-- Welcome message and admin name -->
            <div style="display: flex; gap: 25px; height: 400px; align-items: center; justify-content: left">
                <div>
                    <h1 style="text-align: left">Welcome,</h1>
                    <h1 style="text-align: left">@displayName!</h1>
                </div>
            </div>

            <!-- Section displaying restaurants awaiting approval -->
            <div style="margin-top:40px;">
                <h2 style="font-size:70px;">Pending Restaurants</h2>

                <!-- Modal shown when 'More Details' is clicked -->
                @if (showDetailsModal && selectedRestaurant != null)
                {
                    <!-- Dark overlay behind the modal -->
                    <div style="
                                position:fixed;
                                inset:0;
                                background:rgba(0,0,0,0.7);
                                display:flex;
                                justify-content:center;
                                align-items:center;
                                z-index:1000;">

                        <!-- Modal content displaying restaurant details -->
                        <div style="
                                    background:#1e1e1e;
                                    color:white;
                                    width:60%;
                                    max-width:900px;
                                    padding:40px;
                                    border-radius:12px;
                                    box-shadow:0 0 30px rgba(0,0,0,0.6);">

                            <h2 style="font-size:48px; margin-bottom:25px;">
                                @selectedRestaurant.RestaurantName
                            </h2>

                            <!-- Restaurant location -->
                            <p style="font-size:28px; margin-top:15px;">
                                <strong>Location:</strong><br />
                                @selectedRestaurant.Location
                            </p>

                            <!-- Restaurant category -->
                            <p style="font-size:28px; margin-top:15px;">
                                <strong>Category:</strong><br />
                                @selectedRestaurant.Category
                            </p>

                            <!-- Restaurant logos (if any exist) -->
                            @if (selectedRestaurant.Logo?.Count > 0)
                            {
                                <p style="font-size:28px; margin-top:25px;">
                                    <strong>Logos:</strong>
                                </p>

                                <div style="display:flex; gap:20px; flex-wrap:wrap; margin-top:10px;">
                                    @foreach (var logoUrl in selectedRestaurant.Logo)
                                    {
                                        <img src="@logoUrl"
                                             style="max-height:240px; border-radius:8px;" />
                                    }
                                </div>
                            }

                            <!-- Close button for the modal -->
                            <div style="margin-top:40px; display:flex; justify-content:flex-end;">
                                <button style="font-size:26px; padding:12px 24px;"
                                        @onclick="CloseModal">
                                    Close
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- Loading state while restaurants are being fetched -->
                @if (isLoading)
                {
                    <p style="font-size:50px;">Loading...</p>
                }
                <!-- Message shown when there are no pending restaurants -->
                @if (pendingRestaurants.Count == 0)
                {
                <p style="font-size:50px;">No restaurants awaiting approval.</p>
                }
                <!-- Table displaying all pending restaurants -->
                
                <table style="width:100%; border-collapse:collapse; margin-top:20px;">
                    <thead>
                        <tr style="border-bottom:2px solid #444; font-size:35px;">
                            <th style="padding:14px; text-align:left;">Name</th>
                            <th style="padding:14px; text-align:left;">Location</th>
                            <th style="padding:14px; text-align:left;">Category</th>
                            <th style="padding:14px; text-align:left;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var r in pendingRestaurants)
                        {
                            <tr style="border-bottom:1px solid #333; font-size:32px;">
                                <td style="padding:14px;">@r.RestaurantName</td>
                                <td style="padding:14px;">@r.Location</td>
                                <td style="padding:14px;">@r.Category</td>

                                <!-- Action buttons for each restaurant -->
                                <td style="padding:20px;">
                                    <div style="display:flex; gap:30px">

                                        <!-- Approve restaurant -->
                                        <button style="padding:12px 16px; font-size:25px;"
                                                disabled="@busyIds.Contains(r.RestaurantID)"
                                                @onclick="() => SetStatusAsync(r.RestaurantID, Restaurant.ApprovalStatus.Approved)">
                                            Approve
                                        </button>

                                        <!-- Reject restaurant -->
                                        <button style="padding:12px 16px; font-size:25px;"
                                                disabled="@busyIds.Contains(r.RestaurantID)"
                                                @onclick="() => SetStatusAsync(r.RestaurantID, Restaurant.ApprovalStatus.Rejected)">
                                            Reject
                                        </button>

                                        <!-- View more details -->
                                        <button style="padding:12px 16px; font-size:25px;"
                                                @onclick="() => MoreDetails(r.RestaurantID)">
                                            More Details
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                

                <!-- Displays success or error messages after actions -->
                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <p style="margin-top:18px; font-size:28px;">@message</p>
                }
            </div>
        </div>

@code {

    // ----------------------------
    // Fields / State
    // ----------------------------
    private string? displayName;
    private bool isLoading = true;
    private string? message;
    private bool showDetailsModal = false;
    private Restaurant? selectedRestaurant;
    private List<Restaurant> pendingRestaurants = new();
    private HashSet<int> busyIds = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Get auth state
        var authState = await Auth.GetAuthenticationStateAsync();
        var principal = authState.User;

        // If not authenticated (shouldn't happen in Authorized, but safe guard)
        if (principal?.Identity?.IsAuthenticated != true)
        {
            displayName = "Admin";
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Get the actual Identity user and its custom Name field safely
        var appUser = await UserManager.GetUserAsync(principal);
        displayName = appUser?.Name ?? principal.Identity?.Name ?? "Admin";

        // Load pending restaurants
        await LoadPendingRestaurantsAsync();

        // Update UI
        await InvokeAsync(StateHasChanged);
    }

    // ----------------------------
    // Loads restaurants that are awaiting approval from the database.
    // KEY FIX: IgnoreQueryFilters() in case a global filter is hiding pending rows.
    // Also includes a fallback for default(enum) if your DB has 0 for pending.
    // ----------------------------
    private async Task LoadPendingRestaurantsAsync()
    {
        isLoading = true;
        message = null;

        await using var db = await DbFactory.CreateDbContextAsync();

        pendingRestaurants = await db.Restaurant
            .IgnoreQueryFilters() // <-- critical if you have HasQueryFilter configured
            .Where(r => r.Status == Restaurant.ApprovalStatus.Pending
                     || r.Status == default(Restaurant.ApprovalStatus)) // safe fallback
            .OrderByDescending(r => r.RestaurantID)
            .ToListAsync();

        isLoading = false;
    }

    // ----------------------------
    // Approves or rejects a restaurant and updates the UI.
    // ----------------------------
    private async Task SetStatusAsync(int restaurantId, Restaurant.ApprovalStatus newStatus)
    {
        busyIds.Add(restaurantId);
        message = null;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var restaurant = await db.Restaurant
                .IgnoreQueryFilters() // keep consistent with loading
                .FirstOrDefaultAsync(r => r.RestaurantID == restaurantId);

            if (restaurant is null)
            {
                message = "Restaurant not found (it may have been processed already).";
                await LoadPendingRestaurantsAsync();
                return;
            }

            restaurant.Status = newStatus;
            await db.SaveChangesAsync();

            // Remove immediately from UI list
            pendingRestaurants.RemoveAll(r => r.RestaurantID == restaurantId);

            message = newStatus == Restaurant.ApprovalStatus.Approved
                ? "Restaurant approved."
                : "Restaurant rejected.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
        finally
        {
            busyIds.Remove(restaurantId);
            await InvokeAsync(StateHasChanged);
        }
    }

    // ----------------------------
    // Loads full restaurant details and opens the details modal.
    // KEY FIX: IgnoreQueryFilters() so modal works even if filters exist.
    // ----------------------------
    private async Task MoreDetails(int restaurantId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        selectedRestaurant = await db.Restaurant
            .IgnoreQueryFilters()
            .FirstOrDefaultAsync(r => r.RestaurantID == restaurantId);

        if (selectedRestaurant != null)
        {
            showDetailsModal = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    // ----------------------------
    // Closes the modal.
    // ----------------------------
    private void CloseModal()
    {
        showDetailsModal = false;
        selectedRestaurant = null;
    }

}